generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Letter {
  id           String   @id @default(cuid())
  fakeUsername String
  pinHash      String
  message      String
  reply        String?
  status       String   @default("pending")
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}
